# ============================================================
# ENVIRONMENT VARIABLES — copy to .env.local and fill in
# ============================================================

# ── Stripe ───────────────────────────────────────────────────
# TEST keys (from https://dashboard.stripe.com/test/apikeys)
# Swap BOTH values below to live keys when going to production
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_TEST_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_TEST_PUBLISHABLE_KEY

# Stripe webhook secret — get from Stripe CLI or Dashboard → Webhooks
# Test:  stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# Price ID for the $49 product (create in Stripe Dashboard → Products)
STRIPE_PRICE_ID=price_REPLACE_WITH_YOUR_PRICE_ID

# ── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Notion delivery ─────────────────────────────────────────
# The public Notion duplicate link shown on the thank-you page
NEXT_PUBLIC_NOTION_TEMPLATE_URL=https://www.notion.so/templates/REPLACE_WITH_YOUR_TEMPLATE_DUPLICATE_LINK

# ── Email (optional — Resend or Mailchimp) ───────────────────
# RESEND_API_KEY=re_REPLACE_WITH_YOUR_RESEND_KEY
# MAILCHIMP_API_KEY=REPLACE_WITH_YOUR_MAILCHIMP_KEY
# MAILCHIMP_AUDIENCE_ID=REPLACE_WITH_YOUR_AUDIENCE_ID
